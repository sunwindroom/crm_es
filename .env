# ============================================================
# 企业级CRM系统 - 环境变量配置
# 使用: cp .env.example .env 然后修改各项配置
# ============================================================

# ─── 应用配置 ──────────────────────────────────────────────
APP_ENV=production
APP_PORT=3000
FRONTEND_PORT=80

# ─── 数据库配置 ─────────────────────────────────────────────
DATABASE_HOST=localhost
DATABASE_PORT=5432
DATABASE_USER=crm_user
DATABASE_PASSWORD=crm_password_2025   # 请修改为强密码
DATABASE_NAME=crm_db

# ─── Redis 配置 ──────────────────────────────────────────────
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=        # 请修改或留空（不推荐生产环境留空）

# ─── JWT 配置 ────────────────────────────────────────────────
# 生产环境务必使用强随机字符串，建议64位以上
JWT_SECRET=your-super-secret-jwt-key-change-in-production-2025
JWT_EXPIRES_IN=7d

# ─── MinIO 对象存储 ──────────────────────────────────────────
MINIO_ENDPOINT=localhost
MINIO_PORT=9000
MINIO_ACCESS_KEY=crm_admin
MINIO_SECRET_KEY=crm_password_2025      # 请修改为强密码
MINIO_USE_SSL=false
MINIO_BUCKET=crm-files

# ─── 日志配置 ────────────────────────────────────────────────
LOG_LEVEL=info
LOG_FORMAT=json

# ─── 前端配置（构建时使用）─────────────────────────────────
VITE_API_BASE_URL=http://localhost:3000/api/v1
VITE_APP_TITLE=企业级CRM系统
VITE_PORT=5173
